# ─── LinkedIn Credentials ─────────────────────────────────────────────────────
LINKEDIN_EMAIL=your_linkedin_email@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token below
# 2. Start a chat with your new bot, then open in browser:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Copy the "id" value from the "chat" object — that's your TELEGRAM_CHAT_ID.
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=987654321

# ─── Logging ──────────────────────────────────────────────────────────────────
# Options: error | warn | info | debug
LOG_LEVEL=info
